{program,{let_exp,[{x,{read_exp}},
                   {y,{plus_exp,{integer_const_exp,5},{integer_const_exp,3}}}],
                  {let_exp,[{z,{let_exp,[{'tmp.0',{sub_exp,{var_exp,x},
                                                           {var_exp,y}}},
                                         {'tmp.1',{read_exp}}],
                                        {plus_exp,{var_exp,'tmp.0'},{var_exp,'tmp.1'}}}}],
                           {let_exp,[{'tmp.2',{negative_exp,{var_exp,z}}},
                                     {'tmp.3',{plus_exp,{var_exp,z},{var_exp,x}}}],
                                    {plus_exp,{var_exp,'tmp.2'},{var_exp,'tmp.3'}}}}}}.
